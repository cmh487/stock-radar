# Longbridge API (same as MCP auth)
LONGBRIDGE_APP_KEY=your_app_key_here
LONGBRIDGE_APP_SECRET=your_app_secret_here
LONGBRIDGE_ACCESS_TOKEN=your_access_token_here

# Shared secret between Next.js frontend and this backend
API_SECRET=generate_a_random_string_here

# Server
PORT=4000

# Corporate proxy (local dev only, leave empty for production/Railway)
# e.g. http://proxy.corp.example.com:8080
https_proxy=
http_proxy=
